<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>OpenClaw Dashboard</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@toss/tossface@1.2.5/dist/tossface.css" />
  <script is:inline>
    (function () {
      const saved = localStorage.getItem('oc_theme');
      const sys = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', saved || sys);
    })();
  </script>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    [data-theme="dark"] {
      --bg: #0d0d0d;
      --surface: #161616;
      --border: #2a2a2a;
      --input-bg: #1e1e1e;
      --input-border: #2e2e2e;
      --input-border-focus: #555;
      --text: #e8e8e8;
      --text-muted: #6b6b6b;
      --label-color: #8a8a8a;
      --btn-bg: #ffffff;
      --btn-color: #0d0d0d;
      --btn-hover-bg: #e8e8e8;
      --error: #ff4d4d;
      --shadow: rgba(0,0,0,0.6);
      --toggle-bg: #2a2a2a;
      --toggle-border: #3a3a3a;
    }

    [data-theme="light"] {
      --bg: #f5f5f5;
      --surface: #ffffff;
      --border: #e0e0e0;
      --input-bg: #f8f8f8;
      --input-border: #d8d8d8;
      --input-border-focus: #999;
      --text: #1a1a1a;
      --text-muted: #6b6b6b;
      --label-color: #888;
      --btn-bg: #1a1a1a;
      --btn-color: #ffffff;
      --btn-hover-bg: #333;
      --error: #e03030;
      --shadow: rgba(0,0,0,0.08);
      --toggle-bg: #efefef;
      --toggle-border: #e0e0e0;
    }

    body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--bg);
      font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      transition: background 0.2s;
      position: relative;
    }

    .theme-toggle {
      position: fixed;
      top: 16px;
      right: 16px;
      background: var(--toggle-bg);
      border: 1px solid var(--toggle-border);
      color: var(--text-muted);
      width: 36px;
      height: 36px;
      border-radius: 8px;
      font-size: 16px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s;
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 48px 40px;
      width: 100%;
      max-width: 380px;
      box-shadow: 0 24px 64px var(--shadow);
      transition: background 0.2s, border-color 0.2s;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 32px;
    }

    .logo-icon { font-size: 28px; font-family: 'TossFace', sans-serif; }

    .logo-text {
      font-size: 18px;
      font-weight: 600;
      color: var(--text);
      letter-spacing: -0.3px;
    }

    h1 {
      font-size: 22px;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 8px;
      letter-spacing: -0.4px;
    }

    .subtitle {
      font-size: 14px;
      color: var(--text-muted);
      margin-bottom: 32px;
    }

    label {
      display: block;
      font-size: 12px;
      font-weight: 500;
      color: var(--label-color);
      text-transform: uppercase;
      letter-spacing: 0.8px;
      margin-bottom: 8px;
    }

    .input-wrap { position: relative; margin-bottom: 20px; }

    input[type="password"] {
      width: 100%;
      padding: 12px 16px;
      background: var(--input-bg);
      border: 1px solid var(--input-border);
      border-radius: 10px;
      color: var(--text);
      font-size: 15px;
      outline: none;
      transition: border-color 0.2s;
    }
    input[type="password"]:focus { border-color: var(--input-border-focus); }
    input[type="password"].error { border-color: var(--error); }

    .error-msg {
      font-size: 12px;
      color: var(--error);
      margin-top: -12px;
      margin-bottom: 16px;
      display: none;
    }
    .error-msg.visible { display: block; }

    button.submit {
      width: 100%;
      padding: 13px;
      background: var(--btn-bg);
      color: var(--btn-color);
      border: none;
      border-radius: 10px;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.2s, transform 0.1s;
    }
    button.submit:hover { background: var(--btn-hover-bg); }
    button.submit:active { transform: scale(0.98); }
  </style>
</head>
<body>
  <button class="theme-toggle" id="theme-toggle" title="테마 전환">🌙</button>

  <div class="card">
    <div class="logo">
      <span class="logo-icon">🐾</span>
      <span class="logo-text">OpenClaw</span>
    </div>
    <h1>대시보드 접근</h1>
    <p class="subtitle">비밀번호를 입력하세요</p>

    <label for="password">Password</label>
    <div class="input-wrap">
      <input type="password" id="password" placeholder="••••••••" autocomplete="current-password" />
    </div>
    <p class="error-msg" id="error-msg">비밀번호가 올바르지 않습니다.</p>

    <button class="submit" id="submit-btn">입장하기</button>
  </div>

  <script>
    const HASH = 'c3d4c44e848a92a8ffd0d8cdd78dd95c796104c8005346aff46f8c7376671cf4';

    // Theme
    const toggleBtn = document.getElementById('theme-toggle');
    function applyTheme(theme) {
      document.documentElement.setAttribute('data-theme', theme);
      toggleBtn.textContent = theme === 'dark' ? '🌙' : '☀️';
      localStorage.setItem('oc_theme', theme);
    }
    applyTheme(document.documentElement.getAttribute('data-theme') || 'dark');
    toggleBtn.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme');
      applyTheme(current === 'dark' ? 'light' : 'dark');
    });

    async function sha256(msg) {
      const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(msg));
      return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, '0')).join('');
    }

    async function attempt() {
      const input = document.getElementById('password');
      const errorMsg = document.getElementById('error-msg');
      const hash = await sha256(input.value);

      if (hash === HASH) {
        sessionStorage.setItem('oc_auth', '1');
        window.location.href = '/dashboard';
      } else {
        input.classList.add('error');
        errorMsg.classList.add('visible');
        input.value = '';
        input.focus();
      }
    }

    document.getElementById('submit-btn').addEventListener('click', attempt);
    document.getElementById('password').addEventListener('keydown', e => {
      if (e.key === 'Enter') attempt();
      document.getElementById('password').classList.remove('error');
      document.getElementById('error-msg').classList.remove('visible');
    });
  </script>
</body>
</html>
