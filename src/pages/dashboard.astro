      .bar-row { grid-template-columns: 70px 1fr 80px; gap: 10px; }
      .cards { grid-template-columns: 1fr; }
      .board-view { grid-template-columns: 1fr; }
      .agent-panels { grid-template-columns: 1fr; }
    }
