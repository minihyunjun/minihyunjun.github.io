---
import Layout from '../layouts/Layout.astro';
---
<Layout title="ZPD Dashboard">
  <style is:global>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    [data-theme="dark"] {
      --bg: #0d0d0d;
      --nav-bg: rgba(10,10,10,0.45);
      --surface: #161616;
      --border: #2a2a2a;
      --border-hover: #3a3a3a;
      --text: #e8e8e8;
      --text-sub: #c8c8c8;
      --text-muted: #8a8a8a;
      --text-dim: #5a5a5a;
      --text-faint: #3a3a3a;
      --bar-track: #222;
      --btn-border: #2e2e2e;
      --btn-color: #6b6b6b;
      --btn-hover-color: #e8e8e8;
      --btn-hover-border: #555;
      --badge-bg: #242424;
      --badge-text: #888;
      --skeleton: #1e1e1e;
      --tab-active-bg: rgba(255,255,255,0.08);
      --tab-active-text: #e8e8e8;
      --kanban-col-bg: #111;
      --card-add-border: #2a2a2a;
    }

    [data-theme="light"] {
      --bg: #f5f5f5;
      --nav-bg: rgba(255,255,255,0.45);
      --surface: #ffffff;
      --border: #e0e0e0;
      --border-hover: #c0c0c0;
      --text: #1a1a1a;
      --text-sub: #333;
      --text-muted: #6b6b6b;
      --text-dim: #999;
      --text-faint: #ccc;
      --bar-track: #ebebeb;
      --btn-border: #ddd;
      --btn-color: #888;
      --btn-hover-color: #1a1a1a;
      --btn-hover-border: #999;
      --badge-bg: #f0f0f0;
      --badge-text: #666;
      --skeleton: #ebebeb;
      --tab-active-bg: rgba(0,0,0,0.06);
      --tab-active-text: #1a1a1a;
      --kanban-col-bg: #efefef;
      --card-add-border: #e0e0e0;
    }

    .tossface { font-family: Tossface; }

    body {
      min-height: 100vh;
      background: var(--bg);
      color: var(--text);
      font-family: 'Pretendard Variable', Pretendard, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      transition: background 0.2s, color 0.2s;
    }

    /* ── Navbar ── */
    .navbar {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--nav-bg);
      backdrop-filter: blur(40px) saturate(180%);
      -webkit-backdrop-filter: blur(40px) saturate(180%);
      border-bottom: 1px solid var(--border);
    }

    .nav-inner {
      max-width: 960px;
      margin: 0 auto;
      padding: 0 20px;
      height: 52px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .nav-logo {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 15px;
      font-weight: 600;
      color: var(--text);
      white-space: nowrap;
      flex-shrink: 0;
      text-decoration: none;
    }
    .nav-logo .logo-emoji { font-size: 20px; }

    .nav-tabs {
      display: flex;
      align-items: center;
      gap: 2px;
      flex: 1;
      justify-content: center;
    }

    .nav-tab {
      background: none;
      border: none;
      padding: 6px 14px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 500;
      color: var(--text-muted);
      cursor: pointer;
      transition: background 0.15s, color 0.15s;
      white-space: nowrap;
    }
    .nav-tab:hover { color: var(--text); background: var(--tab-active-bg); }
    .nav-tab.active { background: var(--tab-active-bg); color: var(--tab-active-text); }

    .nav-actions {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
    }

    #theme-toggle {
      background: none;
      border: none;
      font-size: 18px;
      font-family: Tossface;
      cursor: pointer;
      opacity: 0.6;
      transition: opacity 0.15s;
      padding: 4px;
      line-height: 1;
    }
    #theme-toggle:hover { opacity: 1; }

    .logout-btn {
      background: none;
      border: 1px solid var(--btn-border);
      color: var(--btn-color);
      padding: 5px 12px;
      border-radius: 7px;
      font-size: 12px;
      cursor: pointer;
      transition: color 0.2s, border-color 0.2s;
      white-space: nowrap;
    }
    .logout-btn:hover { color: var(--btn-hover-color); border-color: var(--btn-hover-border); }

    /* ── Main layout ── */
    .main {
      max-width: 960px;
      margin: 0 auto;
      padding: 32px 20px 48px;
    }

    /* ── Tab content ── */
    .tab-content { display: none; }
    .tab-content.active { display: block; }

    /* ── Section title ── */
    .section-title {
      font-size: 13px;
      font-weight: 500;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 14px;
    }

    /* ── Overview: Summary ── */
    .summary {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 24px 28px;
      margin-bottom: 28px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      flex-wrap: wrap;
    }
    .summary-main { flex: 1; min-width: 160px; }
    .summary-label { font-size: 15px; color: var(--text-muted); margin-bottom: 6px; }
    .summary-value { font-size: 40px; font-weight: 700; color: var(--text); letter-spacing: -1px; font-family: 'JetBrains Mono', monospace; }
    .summary-sub { font-size: 14px; color: var(--text-dim); margin-top: 4px; }
    .summary-stats { display: flex; gap: 28px; flex-wrap: wrap; }
    .stat-item { text-align: right; }
    .stat-label { font-size: 12px; color: var(--text-dim); margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.5px; }
    .stat-value { font-size: 22px; font-weight: 600; color: var(--text-sub); font-family: 'JetBrains Mono', monospace; }

    /* ── Overview: Bar chart ── */
    .bar-section {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 24px 28px;
      margin-bottom: 28px;
    }
    .bar-row {
      display: grid;
      grid-template-columns: 90px 1fr 100px;
      align-items: center;
      gap: 16px;
      margin-bottom: 18px;
    }
    .bar-row:last-child { margin-bottom: 0; }
    .bar-label { display: flex; align-items: center; gap: 8px; font-size: 15px; font-weight: 500; color: var(--text-sub); }
    .bar-track { height: 10px; background: var(--bar-track); border-radius: 99px; overflow: hidden; }
    .bar-fill { height: 100%; border-radius: 99px; transition: width 0.8s cubic-bezier(0.4,0,0.2,1); }
    .bar-count { font-size: 14px; color: var(--text-muted); text-align: right; font-family: 'JetBrains Mono', monospace; }

    /* ── Overview: Agent cards ── */
    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 16px;
    }
    .agent-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 22px;
      transition: border-color 0.2s;
    }
    .agent-card:hover { border-color: var(--border-hover); }
    .agent-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      margin-bottom: 18px;
      gap: 8px;
      min-width: 0;
    }
    .agent-identity { display: flex; align-items: center; gap: 10px; min-width: 0; flex: 1; }
    .agent-emoji { font-size: 22px; flex-shrink: 0; }
    .agent-info { min-width: 0; flex: 1; }
    .agent-name { font-size: 16px; font-weight: 600; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .agent-role { font-size: 13px; color: var(--text-dim); margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .model-badge {
      background: var(--badge-bg);
      color: var(--badge-text);
      font-size: 10px;
      font-weight: 500;
      padding: 3px 8px;
      border-radius: 99px;
      white-space: nowrap;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .token-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 18px; }
    .token-block-label { font-size: 12px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
    .token-block-value { font-size: 23px; font-weight: 700; color: var(--text); font-family: 'JetBrains Mono', monospace; }
    .ctx-label {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      font-size: 13px;
      color: var(--text-dim);
      margin-bottom: 6px;
      gap: 6px;
    }
    .ctx-label-left { flex-shrink: 0; }
    .ctx-tokens { font-size: 12px; color: var(--text-dim); font-family: 'JetBrains Mono', monospace; }
    .ctx-pct { font-weight: 700; flex-shrink: 0; }
    .ctx-pct.over { color: #f87171; }
    .ctx-track { height: 4px; background: var(--bar-track); border-radius: 99px; overflow: hidden; margin-bottom: 14px; }
    .ctx-fill { height: 100%; border-radius: 99px; max-width: 100%; transition: width 0.8s cubic-bezier(0.4,0,0.2,1); }
    .ctx-fill.over { background: #f87171 !important; }
    .last-activity { font-size: 13px; color: var(--text-dim); }
    .last-activity-time { color: var(--text-muted); }
    .card-stats-row {
      display: flex;
      gap: 16px;
      margin-top: 4px;
    }
    .card-stat { font-size: 12px; color: var(--text-dim); }
    .card-stat span { color: var(--text-muted); }

    /* ── Status dot ── */
    .status-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .status-dot.active {
      background: #4ade80;
      animation: pulse-active 3s ease-in-out infinite;
    }
    .status-dot.idle { background: var(--text-faint); }
    @keyframes pulse-active {
      0%, 100% { box-shadow: 0 0 0 0 rgba(74,222,128,0.5); }
      50%       { box-shadow: 0 0 0 5px rgba(74,222,128,0); }
    }

    /* ── Kanban tab ── */
    .kanban-toolbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 20px;
      gap: 12px;
    }
    .kanban-add-btn {
      display: flex;
      align-items: center;
      gap: 6px;
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--text-muted);
      padding: 8px 16px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      transition: color 0.2s, border-color 0.2s;
    }
    .kanban-add-btn:hover { color: var(--text); border-color: var(--border-hover); }

    .kanban-board { display: none; /* replaced by .board-view */ }

    .kanban-col {
      background: var(--kanban-col-bg);
      border-radius: 14px;
      padding: 16px;
      min-height: 500px;
    }
    .kanban-col-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 14px;
    }
    .kanban-col-title {
      font-size: 13px;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.8px;
    }
    .kanban-col-count {
      font-size: 12px;
      color: var(--text-dim);
      background: var(--badge-bg);
      padding: 2px 7px;
      border-radius: 99px;
    }

    .kanban-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 14px;
      margin-bottom: 10px;
      transition: border-color 0.15s;
    }
    .kanban-card:hover { border-color: var(--border-hover); }
    .kanban-card:last-child { margin-bottom: 0; }

    .kanban-card-title {
      font-size: 15px;
      font-weight: 500;
      color: var(--text);
      margin-bottom: 10px;
      line-height: 1.4;
      word-break: break-word;
    }
    .kanban-card-meta {
      display: flex;
      align-items: center;
      gap: 6px;
      flex-wrap: wrap;
      margin-bottom: 12px;
    }
    .priority-badge {
      font-size: 10px;
      font-weight: 600;
      padding: 2px 7px;
      border-radius: 99px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .priority-high { background: #fef2f2; color: #ef4444; }
    .priority-medium { background: #fffbeb; color: #f59e0b; }
    .priority-low { background: #f0fdf4; color: #22c55e; }
    [data-theme="dark"] .priority-high { background: #2d1515; color: #f87171; }
    [data-theme="dark"] .priority-medium { background: #2d2210; color: #fbbf24; }
    [data-theme="dark"] .priority-low { background: #0f2d1a; color: #4ade80; }

    .agent-tag {
      font-size: 10px;
      color: var(--text-dim);
      background: var(--badge-bg);
      padding: 2px 7px;
      border-radius: 99px;
      display: flex;
      align-items: center;
      gap: 3px;
    }

    .kanban-card-actions {
      display: flex;
      align-items: center;
      gap: 4px;
      justify-content: flex-end;
    }
    .card-action-btn {
      background: none;
      border: none;
      color: var(--text-dim);
      font-size: 12px;
      cursor: pointer;
      padding: 3px 6px;
      border-radius: 5px;
      transition: color 0.15s, background 0.15s;
    }
    .card-action-btn:hover { color: var(--text); background: var(--tab-active-bg); }
    .card-action-btn.delete:hover { color: #f87171; }

    .kanban-empty {
      text-align: center;
      color: var(--text-faint);
      font-size: 14px;
      padding: 24px 0;
    }

    /* ── View toggle ── */
    .view-toggle {
      display: flex;
      background: var(--kanban-col-bg);
      border-radius: 8px;
      padding: 3px;
      gap: 2px;
    }
    .view-btn {
      background: none;
      border: none;
      color: var(--text-muted);
      font-size: 12px;
      font-weight: 500;
      padding: 4px 12px;
      border-radius: 6px;
      cursor: pointer;
      transition: background 0.15s, color 0.15s;
      font-family: inherit;
    }
    .view-btn.active { background: var(--surface); color: var(--text); }
    .view-btn:hover:not(.active) { color: var(--text); }

    /* ── List view ── */
    .list-view { display: none; }
    .list-view.active { display: block; }
    .board-view { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; align-items: start; }
    .board-view.hidden { display: none; }
    .list-table {
      width: 100%;
      border-collapse: collapse;
    }
    .list-table th {
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      color: var(--text-dim);
      padding: 6px 12px;
      text-align: left;
      border-bottom: 1px solid var(--border);
    }
    .list-table td {
      padding: 10px 12px;
      font-size: 14px;
      color: var(--text);
      border-bottom: 1px solid var(--border);
      vertical-align: middle;
    }
    .list-table tr:last-child td { border-bottom: none; }
    .list-table tr:hover td { background: var(--kanban-col-bg); }
    .list-status-badge {
      font-size: 10px;
      font-weight: 600;
      padding: 2px 7px;
      border-radius: 99px;
      white-space: nowrap;
    }
    .list-status-todo   { background: var(--badge-bg); color: var(--text-muted); }
    .list-status-doing  { background: #2d2210; color: #fbbf24; }
    .list-status-done   { background: #0f2d1a; color: #4ade80; }
    [data-theme="light"] .list-status-doing { background: #fffbeb; color: #b45309; }
    [data-theme="light"] .list-status-done  { background: #f0fdf4; color: #15803d; }
    .list-table-wrap {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      overflow: hidden;
    }

    /* ── Archive section ── */
    .archive-section {
      margin-top: 40px;
    }
    .archive-header {
      display: flex;
      align-items: center;
      margin-bottom: 16px;
    }
    .archive-body { display: block; }
    .archive-list {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      overflow: hidden;
    }
    .archive-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      border-bottom: 1px solid var(--border);
    }
    .archive-item:last-child { border-bottom: none; }
    .archive-item-title { font-size: 13px; color: var(--text-sub); flex: 1; min-width: 0; }
    .archive-item-meta  { font-size: 11px; color: var(--text-dim); white-space: nowrap; }
    .archive-restore-btn {
      background: none;
      border: 1px solid var(--btn-border);
      color: var(--text-dim);
      font-size: 11px;
      padding: 3px 9px;
      border-radius: 6px;
      cursor: pointer;
      transition: color 0.15s, border-color 0.15s;
      white-space: nowrap;
      font-family: inherit;
    }
    .archive-restore-btn:hover { color: var(--text); border-color: var(--border-hover); }
    .archive-delete-btn {
      background: none;
      border: none;
      color: var(--text-dim);
      font-size: 12px;
      cursor: pointer;
      padding: 3px 6px;
      border-radius: 5px;
      transition: color 0.15s;
    }
    .archive-delete-btn:hover { color: #f87171; }
    .archive-empty { padding: 24px; text-align: center; font-size: 13px; color: var(--text-faint); }

    /* ── Modal ── */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.5);
      z-index: 200;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .modal-overlay.open { display: flex; }
    .modal {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 28px;
      width: 100%;
      max-width: 400px;
    }
    .modal-title { font-size: 17px; font-weight: 600; color: var(--text); margin-bottom: 20px; }
    .modal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
    .modal-close {
      background: none; border: none; color: var(--text-dim); font-size: 18px;
      cursor: pointer; padding: 2px 6px; border-radius: 6px; transition: color 0.15s;
    }
    .modal-close:hover { color: var(--text); }
    .form-group { margin-bottom: 16px; }
    .form-label { display: block; font-size: 11px; font-weight: 500; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.7px; margin-bottom: 7px; }
    .form-input {
      width: 100%;
      padding: 10px 12px;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      font-size: 14px;
      outline: none;
      transition: border-color 0.2s;
      font-family: inherit;
    }
    .form-input:focus { border-color: var(--btn-hover-border); }
    .form-textarea {
      width: 100%;
      padding: 10px 12px;
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      font-size: 14px;
      outline: none;
      transition: border-color 0.2s;
      font-family: 'Pretendard Variable', Pretendard, -apple-system, sans-serif;
      resize: vertical;
      min-height: 80px;
      line-height: 1.5;
    }
    .form-textarea:focus { border-color: var(--btn-hover-border); }
    .kanban-card { cursor: pointer; }
    .has-desc::after {
      content: '';
      display: inline-block;
      width: 5px; height: 5px;
      background: var(--text-dim);
      border-radius: 50%;
      margin-left: 5px;
      vertical-align: middle;
    }

    .chip-group { display: flex; gap: 8px; flex-wrap: wrap; }
    .chip {
      display: flex;
      align-items: center;
      gap: 5px;
      padding: 6px 14px;
      border-radius: 99px;
      border: 1px solid var(--border);
      background: none;
      color: var(--text-muted);
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.15s;
      font-family: 'Pretendard Variable', Pretendard, -apple-system, sans-serif;
      white-space: nowrap;
    }
    .chip:hover { border-color: var(--border-hover); color: var(--text); }
    .chip.selected { background: var(--text); color: var(--bg); border-color: var(--text); }
    [data-theme="light"] .chip.selected { background: rgba(0,0,0,0.07); color: var(--text); border-color: rgba(0,0,0,0.22); }
    [data-theme="dark"] .chip.selected { background: rgba(255,255,255,0.13); color: var(--text); border-color: rgba(255,255,255,0.32); }

    .chip.priority-high.selected   { background: #fee2e2; border-color: #ef4444; color: #dc2626; }
    .chip.priority-medium.selected { background: #fef3c7; border-color: #f59e0b; color: #b45309; }
    .chip.priority-low.selected    { background: #dcfce7; border-color: #22c55e; color: #15803d; }
    [data-theme="dark"] .chip.priority-high.selected   { background: #3d1a1a; border-color: #f87171; color: #f87171; }
    [data-theme="dark"] .chip.priority-medium.selected { background: #3d2e10; border-color: #fbbf24; color: #fbbf24; }
    [data-theme="dark"] .chip.priority-low.selected    { background: #0f3d20; border-color: #4ade80; color: #4ade80; }

    .chip-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
    .chip-dot.high   { background: #ef4444; }
    .chip-dot.medium { background: #f59e0b; }
    .chip-dot.low    { background: #22c55e; }
    .chip.priority-high.selected   .chip-dot.high   { background: #ef4444; width: 8px; height: 8px; }
    .chip.priority-medium.selected .chip-dot.medium { background: #f59e0b; width: 8px; height: 8px; }
    .chip.priority-low.selected    .chip-dot.low    { background: #22c55e; width: 8px; height: 8px; }
    .modal-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 20px; }
    .btn-cancel {
      background: none;
      border: 1px solid var(--border);
      color: var(--text-muted);
      padding: 8px 16px;
      border-radius: 8px;
      font-size: 14px;
      cursor: pointer;
      transition: color 0.2s, border-color 0.2s;
    }
    .btn-cancel:hover { color: var(--text); border-color: var(--border-hover); }
    .btn-primary {
      background: var(--text);
      color: var(--bg);
      border: none;
      padding: 8px 18px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.2s;
    }
    .btn-primary:hover { opacity: 0.85; }

    /* ── Agents tab ── */
    .agent-panels { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; align-items: start; }
    .agent-panel { position: relative; background: var(--surface); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; }
    .working-badge { position: absolute; top: 12px; right: 14px; font-size: 18px; line-height: 1; font-family: Tossface; }
    .agent-panel-header { display: flex; align-items: center; gap: 14px; padding: 20px 20px 16px; border-bottom: 1px solid var(--border); }
    .pixel-canvas { image-rendering: pixelated; flex-shrink: 0; }
    .agent-panel-info { flex: 1; min-width: 0; }
    .agent-panel-name { font-size: 17px; font-weight: 700; color: var(--text); display: flex; align-items: center; gap: 7px; }
    .agent-panel-role { font-size: 13px; color: var(--text-dim); margin-top: 3px; }
    .agent-panel-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border-bottom: 1px solid var(--border);
    }
    .agent-stat-cell {
      padding: 12px 14px;
      border-right: 1px solid var(--border);
    }
    .agent-stat-cell:last-child { border-right: none; }
    .agent-stat-label { font-size: 10px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.6px; margin-bottom: 4px; }
    .agent-stat-value { font-size: 14px; font-weight: 600; color: var(--text); font-family: 'JetBrains Mono', monospace; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .model-pill {
      display: inline-block;
      margin-top: 6px;
      padding: 2px 9px;
      border-radius: 99px;
      border: 1px solid var(--border);
      font-size: 11px;
      color: var(--text-dim);
      background: var(--badge-bg);
      font-family: 'JetBrains Mono', monospace;
      white-space: nowrap;
    }
    .agent-panel-tasks { padding: 14px 20px 20px; }
    .agent-panel-tasks-label { font-size: 11px; font-weight: 600; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.7px; margin-bottom: 10px; }
    .agent-task-list { display: flex; flex-direction: column; gap: 6px; }
    .agent-task-item {
      display: flex; align-items: flex-start; gap: 10px;
      padding: 9px 12px;
      background: var(--kanban-col-bg);
      border-radius: 8px;
    }
    .agent-task-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; margin-top: 4px; }
    .agent-task-dot.todo  { background: var(--text-faint); }
    .agent-task-dot.doing { background: #fbbf24; animation: pulse-active 2s ease-in-out infinite; }
    .agent-task-dot.done  { background: #4ade80; }
    .agent-task-title { font-size: 13px; color: var(--text-sub); line-height: 1.5; }
    .agent-task-meta  { font-size: 11px; color: var(--text-dim); margin-top: 2px; }
    .agent-no-tasks   { font-size: 13px; color: var(--text-faint); padding: 4px 0; }

    /* ── Skeleton ── */
    .skeleton {
      background: var(--skeleton);
      border-radius: 6px;
      animation: pulse 1.5s ease-in-out infinite;
    }
    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }

    /* ── Footer ── */
    footer {
      margin-top: 48px;
      text-align: center;
      font-size: 12px;
      color: var(--text-faint);
    }

    /* ── Mobile ── */
    @media (max-width: 640px) {
      .nav-inner { padding: 0 16px; height: 48px; }
      .nav-logo span:last-child { display: none; }
      .nav-tab { padding: 5px 10px; font-size: 13px; }
      .main { padding: 20px 16px 48px; }
      .summary { flex-direction: column; gap: 20px; align-items: flex-start; }
      .summary-stats { gap: 20px; width: 100%; }
      .stat-item { text-align: left; }
