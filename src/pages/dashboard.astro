  <script>
    import { startAnim, clearAllAnims } from '../scripts/pixelArt.js';

    // ── Auth guard ──
    if (sessionStorage.getItem('oc_auth') !== '1') {
      window.location.replace('/');
    }

    // ── Theme ──
    const themeBtn = document.getElementById('theme-toggle');
    const sysDark = window.matchMedia('(prefers-color-scheme: dark)');

    function applyTheme(theme, manual = false) {
      document.documentElement.setAttribute('data-theme', theme);
      themeBtn.textContent = theme === 'dark' ? '🌙' : '☀️';
      if (manual) localStorage.setItem('oc_theme', theme);
    }
    applyTheme(localStorage.getItem('oc_theme') || (sysDark.matches ? 'dark' : 'light'));
    sysDark.addEventListener('change', e => {
      if (!localStorage.getItem('oc_theme')) applyTheme(e.matches ? 'dark' : 'light');
    });
    themeBtn.addEventListener('click', () => {
      applyTheme(document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark', true);
    });

    // ── Logout ──
    document.getElementById('logout-btn').addEventListener('click', () => {
      sessionStorage.removeItem('oc_auth');
      window.location.replace('/');
    });

    // ── Tab navigation ──
    const tabs = document.querySelectorAll('.nav-tab');
    const contents = document.querySelectorAll('.tab-content');
    const COLS = ['todo', 'doing', 'done'];

    function switchTab(tabName) {
      tabs.forEach(t => t.classList.toggle('active', t.dataset.tab === tabName));
      contents.forEach(c => c.classList.toggle('active', c.id === 'tab-' + tabName));
      location.hash = tabName === 'overview' ? '' : tabName;
    }

    tabs.forEach(t => t.addEventListener('click', () => switchTab(t.dataset.tab)));

    // Restore tab from hash
    const hash = location.hash.replace('#', '');
    if (['kanban', 'agents'].includes(hash)) switchTab(hash);

    // ── Utilities ──
    function fmt(n) { return (n || 0).toLocaleString('ko-KR'); }
    function relTime(ms) {
      if (!ms) return '알 수 없음';
      const diff = Date.now() - ms;
      const sec = Math.floor(diff / 1000);
      if (sec < 60) return '방금 전';
      const min = Math.floor(sec / 60);
      if (min < 60) return `${min}분 전`;
      const hr = Math.floor(min / 60);
      if (hr < 24) return `${hr}시간 전`;
      return `${Math.floor(hr / 24)}일 전`;
    }
    function isActive(ms) {
      return ms && (Date.now() - ms) < 60 * 60 * 1000;
    }
    function activeDuration(ms) {
      if (!ms) return '—';
      const h = Math.floor(ms / 3600000);
      const m = Math.floor((ms % 3600000) / 60000);
      if (h >= 1) return `${h}시간 ${m}분`;
      return `${m}분`;
    }

    // ── Overview render ──
    function renderOverview(data) {
      _cachedTokens = data;
      const agents = data.agents || [];
      const totalInput = agents.reduce((s, a) => s + (a.inputTokens || 0), 0);
      const totalOutput = agents.reduce((s, a) => s + (a.outputTokens || 0), 0);
      const totalUsed = totalInput + totalOutput;

      const totalActiveMs = agents.reduce((s, a) => s + (a.activeMs || 0), 0);
      const totalSessions = agents.reduce((s, a) => s + (a.sessionCount || 0), 0);

      document.getElementById('total-used').textContent = fmt(totalUsed);
      document.getElementById('total-input').textContent = fmt(totalInput);
      document.getElementById('total-output').textContent = fmt(totalOutput);
      document.getElementById('total-active-time').textContent = activeDuration(totalActiveMs) || '—';
      document.getElementById('total-sessions').textContent = totalSessions ? totalSessions + '회' : '—';
      document.getElementById('agent-count-label').textContent = `에이전트 ${agents.length}명 합산`;
      updateSummaryTaskCount();
      const updatedText = data.updatedAt
        ? new Date(data.updatedAt).toLocaleString('ko-KR', { timeZone: 'Asia/Seoul' })
        : '알 수 없음';
      document.getElementById('data-updated').textContent = updatedText;

      // Bar chart
      document.getElementById('bar-section').innerHTML = agents.map(a => {
        const used = (a.inputTokens || 0) + (a.outputTokens || 0);
        const pct = totalUsed > 0 ? ((used / totalUsed) * 100).toFixed(1) : '0';
        return `<div class="bar-row">
          <span class="bar-label"><span class="tossface">${a.emoji}</span><span>${a.name}</span></span>
          <div class="bar-track"><div class="bar-fill" style="width:${pct}%;background:${a.color}"></div></div>
          <span class="bar-count">${fmt(used)}</span>
        </div>`;
      }).join('');

      // Render agent panels with pixel art
      renderAgentPanels();
    }

    // ── Data fetch ──
    async function loadData() {
      try {
        const res = await fetch('/data/tokens.json?t=' + Date.now());
        if (!res.ok) throw new Error(res.status);
        const data = await res.json();
        renderOverview(data);
      } catch (e) {
        console.error('Failed to load tokens:', e);
      }
    }
    setInterval(loadData, 5 * 60 * 1000);
    loadData();

    // ── Kanban ──
    const AGENT_EMOJIS = { gary: '🐍', judy: '🐰', nick: '🦊' };
    const AGENT_NAMES  = { gary: '개리', judy: '주디', nick: '닉' };
    const PRIORITY_LABELS = { high: '높음', medium: '보통', low: '낮음' };

    let kanbanData = { todo: [], doing: [], done: [], archive: [] };

    async function loadKanban() {
      try {
        const res = await fetch('/data/kanban.json?t=' + Date.now());
        if (!res.ok) throw new Error(res.status);
        kanbanData = await res.json();
        if (!kanbanData.archive) kanbanData.archive = [];
      } catch (e) {
        console.error('Failed to load kanban:', e);
      }
      renderKanban();
      renderListView();
      renderArchive();
    }

    function updateSummaryTaskCount() {
      const total = COLS.reduce((s, col) => s + (kanbanData[col] || []).length, 0);
      const el = document.getElementById('total-tasks');
      if (el) el.textContent = total + '개';
    }

    function renderKanban() {
      const data = kanbanData;
      updateSummaryTaskCount();
      COLS.forEach((col, colIdx) => {
        const tasks = data[col] || [];
        document.getElementById(`count-${col}`).textContent = tasks.length;
        document.getElementById(`col-${col}`).innerHTML = tasks.length === 0
          ? `<p class="kanban-empty">태스크 없음</p>`
          : tasks.map((task, i) => {
              const canLeft = colIdx > 0;
              const isDone  = col === 'done';
              const agentTag = task.agent
                ? `<span class="agent-tag tossface">${AGENT_EMOJIS[task.agent]} ${AGENT_NAMES[task.agent]}</span>`
                : '';
              const hasDesc = task.description && task.description.trim();
              return `<div class="kanban-card" onclick="openDetail('${col}',${i})">
                <p class="kanban-card-title${hasDesc ? ' has-desc' : ''}">${escHtml(task.title)}</p>
                <div class="kanban-card-meta">
                  <span class="priority-badge priority-${task.priority}">${PRIORITY_LABELS[task.priority]}</span>
                  ${agentTag}
                </div>
                <div class="kanban-card-actions" onclick="event.stopPropagation()">
                  ${canLeft ? `<button class="card-action-btn" onclick="moveTask('${col}',${i},'${COLS[colIdx-1]}')">←</button>` : ''}
                  ${isDone  ? `<button class="card-action-btn" title="아카이브" onclick="archiveTask('${col}',${i})">🗂</button>` : ''}
                  <button class="card-action-btn delete" onclick="deleteTask('${col}',${i})">✕</button>
                </div>
              </div>`;
            }).join('');
      });
    }

    function escHtml(str) {
      return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    window.moveTask = function(fromCol, idx, toCol) {
      const [task] = kanbanData[fromCol].splice(idx, 1);
      kanbanData[toCol].push(task);
      renderKanban();
      renderListView();
    };

    window.deleteTask = function(col, idx) {
      kanbanData[col].splice(idx, 1);
      renderKanban();
      renderListView();
    };

    window.archiveTask = function(col, idx) {
      const [task] = kanbanData[col].splice(idx, 1);
      task.archivedAt = Date.now();
      kanbanData.archive.push(task);
      renderKanban();
      renderListView();
      renderArchive();
    };

    window.unarchiveTask = function(idx) {
      const [task] = kanbanData.archive.splice(idx, 1);
      delete task.archivedAt;
      kanbanData.todo.push(task);
      renderKanban();
      renderListView();
      renderArchive();
    };

    window.deleteArchiveTask = function(idx) {
      kanbanData.archive.splice(idx, 1);
      renderArchive();
    };

    // ── List view render ──
    const STATUS_LABELS = { todo: '대기', doing: '진행 중', done: '완료' };
    function renderListView() {
      const allTasks = COLS.flatMap(col => (kanbanData[col] || []).map(t => ({ ...t, col })));
      const tbody = document.getElementById('list-tbody');
      if (!tbody) return;
      if (allTasks.length === 0) {
        tbody.innerHTML = `<tr><td colspan="5" style="text-align:center;padding:32px;color:var(--text-faint)">태스크 없음</td></tr>`;
        return;
      }
      tbody.innerHTML = allTasks.map((task, i) => {
        const agentStr = task.agent
          ? `<span class="agent-tag tossface" style="display:inline-flex">${AGENT_EMOJIS[task.agent]} ${AGENT_NAMES[task.agent]}</span>`
          : '<span style="color:var(--text-faint)">—</span>';
        return `<tr>
          <td><span class="list-status-badge list-status-${task.col}">${STATUS_LABELS[task.col]}</span></td>
          <td>${escHtml(task.title)}</td>
          <td><span class="priority-badge priority-${task.priority}">${PRIORITY_LABELS[task.priority]}</span></td>
          <td>${agentStr}</td>
          <td style="text-align:right">
            ${task.col === 'done' ? `<button class="card-action-btn" title="아카이브" onclick="archiveListTask('${task.col}',${kanbanData[task.col].indexOf(task)})">🗂</button>` : ''}
            <button class="card-action-btn delete" onclick="deleteListTask('${task.col}',${kanbanData[task.col].indexOf(task)})">✕</button>
          </td>
        </tr>`;
      }).join('');
    }

    window.archiveListTask = function(col, idx) { window.archiveTask(col, idx); };
    window.deleteListTask  = function(col, idx) { window.deleteTask(col, idx); };

    // ── Archive render ──
    function renderArchive() {
      const items = kanbanData.archive || [];
      const el = document.getElementById('archive-list');
      if (!el) return;
      if (items.length === 0) {
        el.innerHTML = `<p class="archive-empty">아카이브된 태스크 없음</p>`;
        return;
      }
      el.innerHTML = items.map((task, i) => {
        const agentStr = task.agent
          ? `<span class="tossface">${AGENT_EMOJIS[task.agent]}</span> ${AGENT_NAMES[task.agent]}`
          : '';
        const archivedDate = task.archivedAt
          ? new Date(task.archivedAt).toLocaleDateString('ko-KR')
          : '';
        return `<div class="archive-item">
          <span class="priority-badge priority-${task.priority}">${PRIORITY_LABELS[task.priority]}</span>
          <span class="archive-item-title">${escHtml(task.title)}</span>
          <span class="archive-item-meta">${agentStr ? agentStr + ' · ' : ''}${archivedDate}</span>
          <button class="archive-restore-btn" onclick="unarchiveTask(${i})">복원</button>
          <button class="archive-delete-btn" onclick="deleteArchiveTask(${i})">✕</button>
        </div>`;
      }).join('');
    }

    // ── View toggle ──
    document.querySelectorAll('.view-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.view-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const view = btn.dataset.view;
        document.getElementById('board-view').classList.toggle('hidden', view !== 'board');
        document.getElementById('list-view').classList.toggle('active', view === 'list');
        if (view === 'list') renderListView();
      });
    });

    // ── Detail modal ──
    const detailModal = document.getElementById('detail-modal');
    let detailTarget = null; // { col, idx }

    window.openDetail = function(col, idx) {
      const task = kanbanData[col][idx];
      detailTarget = { col, idx };
      document.getElementById('detail-title').value = task.title || '';
      document.getElementById('detail-desc').value = task.description || '';
      setChip('detail-agent', task.agent || '');
      setChip('detail-priority', task.priority || 'medium');
      setChip('detail-col', col);
      detailModal.classList.add('open');
      document.getElementById('detail-title').focus();
    };

    document.getElementById('detail-close').addEventListener('click', () => detailModal.classList.remove('open'));
    detailModal.addEventListener('click', e => { if (e.target === detailModal) detailModal.classList.remove('open'); });

    document.getElementById('detail-save').addEventListener('click', () => {
      if (!detailTarget) return;
      const { col, idx } = detailTarget;
      const task = kanbanData[col][idx];
      const newCol = getChip('detail-col') || col;
      task.title = document.getElementById('detail-title').value.trim() || task.title;
      task.description = document.getElementById('detail-desc').value.trim();
      task.agent = getChip('detail-agent') || null;
      task.priority = getChip('detail-priority') || 'medium';
      if (newCol !== col) {
        kanbanData[col].splice(idx, 1);
        kanbanData[newCol].push(task);
      }
      renderKanban();
      detailModal.classList.remove('open');
    });

    document.getElementById('detail-delete').addEventListener('click', () => {
      if (!detailTarget) return;
      kanbanData[detailTarget.col].splice(detailTarget.idx, 1);
      renderKanban();
      detailModal.classList.remove('open');
    });

    // ── Chip groups ──
    function getChip(groupId) {
      const sel = document.querySelector(`#${groupId} .chip.selected`);
      return sel ? sel.dataset.value : '';
    }
    function setChip(groupId, value) {
      document.querySelectorAll(`#${groupId} .chip`).forEach(c =>
        c.classList.toggle('selected', c.dataset.value === value)
      );
    }
    document.querySelectorAll('.chip-group').forEach(group => {
      group.querySelectorAll('.chip').forEach(chip => {
        chip.addEventListener('click', () => {
          group.querySelectorAll('.chip').forEach(c => c.classList.remove('selected'));
          chip.classList.add('selected');
        });
      });
    });

    // Modal
    const modal = document.getElementById('modal');
    document.getElementById('kanban-add-btn').addEventListener('click', () => {
      document.getElementById('task-title').value = '';
      document.getElementById('task-desc').value = '';
      setChip('task-agent', '');
      setChip('task-priority', 'medium');
      setChip('task-col', 'todo');
      modal.classList.add('open');
      document.getElementById('task-title').focus();
    });
    document.getElementById('modal-cancel').addEventListener('click', () => modal.classList.remove('open'));
    modal.addEventListener('click', e => { if (e.target === modal) modal.classList.remove('open'); });

    document.getElementById('modal-save').addEventListener('click', () => {
      const title = document.getElementById('task-title').value.trim();
      if (!title) { document.getElementById('task-title').focus(); return; }
      const col = getChip('task-col') || 'todo';
      kanbanData[col].push({
        id: Date.now(),
        title,
        description: document.getElementById('task-desc').value.trim(),
        agent: getChip('task-agent') || null,
        priority: getChip('task-priority') || 'medium',
        createdAt: Date.now()
      });
      renderKanban();
      modal.classList.remove('open');
    });

    document.getElementById('task-title').addEventListener('keydown', e => {
      if (e.key === 'Enter') document.getElementById('modal-save').click();
    });

    loadKanban();

    // ── Agent panels ──
    const _SL = { todo: '대기', doing: '진행 중', done: '완료' };
    const _PL = { high: '높음', medium: '보통', low: '낮음' };
    let _cachedTokens = null;

    function renderAgentPanels() {
      if (!_cachedTokens) return;
      clearAllAnims();
      const kd = kanbanData;
      document.getElementById('agent-panels').innerHTML = _cachedTokens.agents.map(a => {
        const modelShort = (a.model || '').split('/').pop();
        const totalTokens = (a.inputTokens || 0) + (a.outputTokens || 0);
        const tasks = ['todo','doing','done'].flatMap(col =>
          (kd[col] || []).map(t => ({ ...t, col }))
        ).filter(t => t.agent === a.id);
        const tasksHtml = tasks.length === 0
          ? '<p class="agent-no-tasks">배정된 태스크 없음</p>'
          : tasks.map(t => `<div class="agent-task-item">
              <div class="agent-task-dot ${t.col}"></div>
              <div>
                <p class="agent-task-title">${escHtml(t.title)}</p>
                <p class="agent-task-meta">${_SL[t.col]}${t.priority ? ' · ' + _PL[t.priority] : ''}</p>
              </div>
            </div>`).join('');
        const isWorking = a.id === 'gary'; // TODO: replace with real working state
        return `<div class="agent-panel">
          ${isWorking ? '<span class="working-badge tossface">🚧</span>' : ''}
          <div class="agent-panel-header">
            <canvas class="pixel-canvas" id="px-${a.id}" width="54" height="48"></canvas>
            <div class="agent-panel-info">
              <p class="agent-panel-name">
                <span class="tossface">${a.emoji}</span>
                <span>${a.name}</span>
                <span class="status-dot ${isActive(a.updatedAt) ? 'active' : 'idle'}"></span>
              </p>
              <p class="agent-panel-role">${a.role}</p>
              <span class="model-pill">${modelShort}</span>
            </div>
          </div>
          <div class="agent-panel-stats">
            <div class="agent-stat-cell">
              <p class="agent-stat-label">토큰</p>
              <p class="agent-stat-value">${fmt(totalTokens)}</p>
            </div>
            <div class="agent-stat-cell">
              <p class="agent-stat-label">활성시간</p>
              <p class="agent-stat-value">${activeDuration(a.activeMs) || '—'}</p>
            </div>
            <div class="agent-stat-cell">
              <p class="agent-stat-label">마지막 활동</p>
              <p class="agent-stat-value" style="font-size:12px">${relTime(a.updatedAt)}</p>
            </div>
          </div>
          <div class="agent-panel-tasks">
            <p class="agent-panel-tasks-label">작업 ${tasks.length > 0 ? `(${tasks.length})` : ''}</p>
            <div class="agent-task-list">${tasksHtml}</div>
          </div>
        </div>`;
      }).join('');
      _cachedTokens.agents.forEach(a => startAnim(a.id));
    }

    // Re-render agents tab on tab click
    tabs.forEach(t => {
      if (t.dataset.tab === 'agents') t.addEventListener('click', renderAgentPanels);
    });
  </script>
</Layout>
